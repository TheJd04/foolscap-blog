# Copy this file to .env and fill in your real values. Never commit .env.

# Your MongoDB Atlas connection string
# Get this from Atlas -> Database -> Connect -> Drivers
# Example: mongodb+srv://yourUser:yourPassword@cluster0.xxxxx.mongodb.net/foolscap?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/foolscap?retryWrites=true&w=majority

# Any long random string. You can generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# How long login tokens stay valid
JWT_EXPIRES_IN=7d

# Port the API runs on
PORT=5000

# The URL your frontend runs on (for CORS)
CLIENT_URL=http://localhost:5173
